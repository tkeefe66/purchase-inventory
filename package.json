{
  "name": "purchase-inventory",
  "version": "0.0.1",
  "private": true,
  "description": "Personal purchase-ingest + categorization platform that powers domain-specialist Claude agents (Outdoor first).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth": "tsx scripts/auth.ts",
    "bootstrap-sheet": "tsx scripts/bootstrap-sheet.ts",
    "inspect-sheets": "tsx scripts/inspect-sheets.ts",
    "migrate-to-master": "tsx scripts/migrate-to-master.ts",
    "backfill-urls": "tsx scripts/backfill-urls.ts",
    "fetch-fixtures": "tsx scripts/fetch-fixtures.ts",
    "telegram-setup": "tsx scripts/telegram-setup.ts",
    "import-history": "tsx scripts/import-history.ts",
    "cron": "tsx apps/cron/index.ts",
    "cron:dry": "tsx apps/cron/index.ts --dry-run",
    "bot": "tsx apps/bot/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "cheerio": "^1.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
